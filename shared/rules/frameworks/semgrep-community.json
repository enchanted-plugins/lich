        "javascript.express.security.audit.express-open-redirect",
        "javascript.express.security.audit.express-missing-helmet",
        "javascript.express.security.audit.eval-injection",
        "javascript.express.security.audit.res-sendfile-path-traversal",
        "javascript.express.security.cookie-missing-httponly",
